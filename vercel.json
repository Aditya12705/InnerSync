{
    "version": 2,
    "builds": [
        {
            "src": "Backend/src/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "Frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/Backend/src/server.js"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/Frontend/assets/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/Frontend/images/$1"
        },
        {
            "source": "/favicon.(.*)",
            "destination": "/Frontend/favicon.$1"
        },
        {
            "source": "/((?!api|assets|images|favicon).*)",
            "destination": "/Frontend/index.html"
        }
    ]
}