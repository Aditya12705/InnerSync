{
    "version": 2,
    "builds": [
        {
            "src": "Backend/src/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "Frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/Backend/src/server.js"
        },
        {
            "src": "/(assets|favicon|images|public)/(.*)",
            "dest": "/Frontend/$1/$2"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/Frontend/$1",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/Frontend/index.html"
        }
    ]
}